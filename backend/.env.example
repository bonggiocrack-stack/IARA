# Backend environment variables
# Copiá este archivo a .env y completá los valores

NODE_ENV=development
PORT=3000

# Admin credentials
ADMIN_USER=iara
ADMIN_PASS=pulseras2026

# Editor credentials (opcional)
EDITOR_USER=
EDITOR_PASS=

# JWT
JWT_SECRET=change_me_in_production_use_a_secure_random_string

# Database (SQLite local por defecto, o DATABASE_URL para PostgreSQL en producción)
# Si usás PostgreSQL, setee DATABASE_URL con la connection string de Neon/Render
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# CORS (separados por coma sin espacios)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=TEST-XXXXXXXXXXXXXX

# Cloudinary (opcional - para upload de imágenes)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
