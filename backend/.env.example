# Base de datos (PostgreSQL)
# Formato: postgresql://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql://user:password@localhost:5432/iara

# Token de acceso de MercadoPago (Backend)
# https://www.mercadopago.com.ar/developers/panel/credentials
MP_ACCESS_TOKEN=TEST-XXXX

# Credenciales admin (cambiar en producción)
ADMIN_USER=admin
ADMIN_PASS=XXXXXXXX

# Secreto JWT para sesión admin
JWT_SECRET=tu_secreto_jwt_aqui

# Origen permitido para CORS (frontend)
ALLOWED_ORIGIN=http://localhost:3000

# Puerto del backend
PORT=3000

# Cloudinary (para backup de imágenes)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Correo Argentino (cálculo de envío)
CORREO_ARGENTINO_API_KEY=
