# Backend environment variables
# Copiá este archivo a .env y completá los valores

NODE_ENV=development
PORT=3000

# Admin credentials
ADMIN_USER=iara
ADMIN_PASS=pulseras2026

# JWT
JWT_SECRET=change_me_in_production_use_a_secure_random_string

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/iara?sslmode=require

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# MercadoPago (opcional)
MERCADOPAGO_ACCESS_TOKEN=TEST-XXXXXXXXXXXXXX
MERCADOPAGO_PUBLIC_KEY=TEST-XXXXXXXXXXXXXX

# Cloudinary (opcional - para upload de imágenes)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
