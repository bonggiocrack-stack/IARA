{
  "name": "artesania-gualeguay",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest --config tests/unit/jest.config.js --testEnvironment jsdom",
    "lint": "eslint frontend/js/ tests/ --ext .js",
    "format": "prettier --write \"**/*.{js,json,css,html}\"",
    "lint:fix": "eslint frontend/js/ tests/ --ext .js --fix",
